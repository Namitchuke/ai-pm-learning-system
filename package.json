{
    "name": "ai-pm-learning-system",
    "version": "1.0.0",
    "description": "AI PM Learning System - Multi-user roadmap tracker",
    "main": "server/index.js",
    "scripts": {
        "dev": "concurrently \"node server/index.js\" \"cd client && npx vite --port 5173\"",
        "server": "node server/index.js",
        "client": "cd client && npx vite --port 5173",
        "build": "cd client && npx vite build",
        "seed": "node server/scripts/seed.js",
        "start": "node server/index.js"
    },
    "dependencies": {
        "express": "^4.18.2",
        "mongoose": "^7.6.3",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "passport-local": "^1.0.0",
        "express-session": "^1.17.3",
        "connect-mongo": "^5.1.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}